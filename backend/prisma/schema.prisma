generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agente {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  password  String
  role      Role @default(AGENTE)
  createdAt DateTime @default(now())

  turnos    Turno[]
  visitas   Visita[]
  fechamentos   ImovelFechado[]
  tentativas    TentativaRecuperacao[]
}

model Turno {
  id                   Int      @id @default(autoincrement())
  data                 DateTime
  municipio            String
  ciclo                String
  localidade           String
  categoriaLocalidade  String?
  zona                 String?
  atividade            String?

  agenteId             Int
  agente               Agente   @relation(fields: [agenteId], references: [id])

  nomeAgente           String
  
  createdAt            DateTime @default(now())
  finalizadoEm         DateTime?

  encerradoAutomaticamente Boolean  @default(false)
  motivoEncerramento        String?
  
  visitas              Visita[]
  fechamentos   ImovelFechado[]
  tentativas    TentativaRecuperacao[]
}

model Imovel {
  id          Int     @id @default(autoincrement())
  
  codigo      String  @unique   // identificador único do imóvel
  municipio   String?
  localidade  String?
  quarteirao  String?
  logradouro  String?
  numero      String?
  complemento String?

  createdAt   DateTime @default(now())

  visitas     Visita[]
  fechamentos   ImovelFechado[]
}

model Visita {
  id            Int      @id @default(autoincrement())

  turnoId       Int
  turno         Turno    @relation(fields: [turnoId], references: [id])

  agenteId      Int
  agente        Agente   @relation(fields: [agenteId], references: [id])

  imovelId      Int
  imovel        Imovel   @relation(fields: [imovelId], references: [id])

  tipoVisita    TipoVisita

  horarioEntrada DateTime?
  informacao     String?

  a1                   Int?
  a2                   Int?
  b                    Int?
  c                    Int?
  d1                   Int?
  d2                   Int?
  e                    Int?

  inspL1               Boolean?
  imTrat               Boolean?

  amostraInicial       Int?
  amostraFinal         Int?
  qtdDepTrat           Int?
  depositosEliminados  Int?
  qtdTubitos           Int?
  quedaGramas          Int?

  criadoEm       DateTime @default(now())
  imovelFechado         ImovelFechado? @relation("VisitaFechamento")
  imovelRecuperacao     ImovelFechado? @relation("VisitaRecuperacao")
}
model ImovelFechado {
  id        Int      @id @default(autoincrement())

  imovelId  Int
  imovel    Imovel   @relation(fields: [imovelId], references: [id])

  turnoId   Int
  turno     Turno    @relation(fields: [turnoId], references: [id])

  agenteId  Int
  agente    Agente   @relation(fields: [agenteId], references: [id])

  tipoImovel  String   // "R-F", "C-F", "TB-F", "PE-F", "O-F", "RECUSA"
  status      StatusFechado @default(FECHADO)

  motivoFechamento  String?
  dataFechamento    DateTime @default(now())
  dataRecuperacao   DateTime?

  visitaOrigemId    Int?     @unique  // Visita que gerou o fechamento
  visitaOrigem    Visita?  @relation("VisitaFechamento", fields: [visitaOrigemId], references: [id])

  visitaRecuperacaoId Int?   @unique  // Visita que recuperou
  visitaRecuperacao   Visita? @relation("VisitaRecuperacao", fields: [visitaRecuperacaoId], references: [id])

  tentativas  TentativaRecuperacao[]

  criadoEm   DateTime @default(now())
}

model TentativaRecuperacao {
  id              Int      @id @default(autoincrement())

  imovelFechadoId Int
  imovelFechado   ImovelFechado @relation(fields: [imovelFechadoId], references: [id])

  agenteId  Int
  agente    Agente @relation(fields: [agenteId], references: [id])

  turnoId   Int
  turno     Turno  @relation(fields: [turnoId], references: [id])

  resultado   ResultadoTentativa
  observacao  String?
  criadoEm    DateTime @default(now())
}

enum StatusFechado {
  FECHADO
  PENDENTE    // 2ª tentativa em diante sem sucesso
  RECUPERADO
  RECUSADO
}

enum ResultadoTentativa {
  SEM_RESPOSTA
  RECUSA
  RECUPERADO
}

enum Role {
  AGENTE
  COORDENADOR
}
enum TipoVisita {
  NORMAL
  R_F
  C_F
  TB_F
  PE_F
  O_F
  RECUSA
  RECUPERACAO
}